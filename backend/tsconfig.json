{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "./dist",
    "rootDir": "./",
    "skipLibCheck": true,
    "types": ["jest", "node"],
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules"],
}
